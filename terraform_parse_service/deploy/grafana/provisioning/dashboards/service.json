{
  "uid": "terraform-parse-service",
  "title": "Terraform Parse Service",
  "tags": ["terraform", "sre-assignment"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 6,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "route",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(traces_spanmetrics_calls_total{service=\"terraform-parse-service\",span_kind=\"SPAN_KIND_SERVER\"}, span_name)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "provider",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(terraform_templates_loaded, provider)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "resource",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(terraform_generation_total{provider=~\"$provider\"}, resource)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request rate",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(traces_spanmetrics_calls_total{service=\"terraform-parse-service\",span_kind=\"SPAN_KIND_SERVER\",span_name=~\"$route\"}[$__rate_interval]))",
          "legendFormat": "requests"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "id": 2,
      "title": "Request error ratio",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(traces_spanmetrics_calls_total{service=\"terraform-parse-service\",span_kind=\"SPAN_KIND_SERVER\",span_name=~\"$route\",status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / clamp_min(sum(rate(traces_spanmetrics_calls_total{service=\"terraform-parse-service\",span_kind=\"SPAN_KIND_SERVER\",span_name=~\"$route\"}[$__rate_interval])), 0.001)",
          "legendFormat": "errors"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "id": 3,
      "title": "Request p95",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=\"terraform-parse-service\",span_kind=\"SPAN_KIND_SERVER\",span_name=~\"$route\"}[$__rate_interval])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "id": 4,
      "title": "Generation success ratio",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(terraform_generation_total{provider=~\"$provider\",resource=~\"$resource\",status=\"success\"}[$__rate_interval])) / clamp_min(sum(rate(terraform_generation_total{provider=~\"$provider\",resource=~\"$resource\"}[$__rate_interval])), 0.001)",
          "legendFormat": "success"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2, "thresholds": { "mode": "absolute", "steps": [{ "color": "red" }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 }] } }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "id": 5,
      "title": "Request latency by route",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le, span_name) (rate(traces_spanmetrics_latency_bucket{service=\"terraform-parse-service\",span_kind=\"SPAN_KIND_SERVER\",span_name=~\"$route\"}[$__rate_interval])))",
          "legendFormat": "p50 {{span_name}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le, span_name) (rate(traces_spanmetrics_latency_bucket{service=\"terraform-parse-service\",span_kind=\"SPAN_KIND_SERVER\",span_name=~\"$route\"}[$__rate_interval])))",
          "legendFormat": "p95 {{span_name}}"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le, span_name) (rate(traces_spanmetrics_latency_bucket{service=\"terraform-parse-service\",span_kind=\"SPAN_KIND_SERVER\",span_name=~\"$route\"}[$__rate_interval])))",
          "legendFormat": "p99 {{span_name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 6,
      "title": "Requests by trace outcome",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (span_name, status_code) (rate(traces_spanmetrics_calls_total{service=\"terraform-parse-service\",span_kind=\"SPAN_KIND_SERVER\",span_name=~\"$route\"}[$__rate_interval]))",
          "legendFormat": "{{status_code}} {{span_name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 7,
      "title": "Terraform generation p95",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, provider, resource) (rate(terraform_generation_duration_seconds_bucket{provider=~\"$provider\",resource=~\"$resource\"}[$__rate_interval])))",
          "legendFormat": "{{provider}} / {{resource}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 8,
      "title": "Terraform generation outcomes",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider, resource, status) (rate(terraform_generation_total{provider=~\"$provider\",resource=~\"$resource\"}[$__rate_interval]))",
          "legendFormat": "{{provider}} / {{resource}} / {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 9,
      "title": "Rendered Terraform size p95",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, provider, resource) (rate(terraform_rendered_bytes_bucket{provider=~\"$provider\",resource=~\"$resource\"}[$__rate_interval])))",
          "legendFormat": "{{provider}} / {{resource}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 10,
      "title": "Template reload outcomes",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider, status) (rate(terraform_template_reloads_total{provider=~\"$provider\"}[$__rate_interval]))",
          "legendFormat": "{{provider}} / {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 11,
      "title": "Loaded templates",
      "type": "stat",
      "gridPos": { "x": 0, "y": 25, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider) (terraform_templates_loaded{provider=~\"$provider\"})",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" }
    },
    {
      "id": 12,
      "title": "Template reload p95",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 25, "w": 16, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(terraform_template_reload_duration_seconds_bucket{provider=~\"$provider\"}[$__rate_interval])))",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } }
    }
  ],
  "annotations": { "list": [] }
}
